{
  "name": "the-masonry",
  "compatibility_date": "2026-04-16",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "binding": "ASSETS",
    "directory": "./dist",
  },
  "observability": {
    "enabled": true,
  },
  "routes": [
    {
      "pattern": "brockshaffer.dev",
      "custom_domain": true,
    },
  ],
}
