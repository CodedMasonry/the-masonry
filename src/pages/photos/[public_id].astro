---
import "@/styles/global.css";
import { getCollection } from "astro:content";
import { CldImage } from "astro-cloudinary";
import { Button } from "@/components/ui/button";
import { Separator } from "@/components/ui/separator";
import PhotoActions from "@/components/PhotoActions";
import { v2 as cloudinary } from "cloudinary";
import { z } from "zod";
import {
    Camera,
    Aperture,
    Clock,
    Settings,
    Globe,
    User,
    CalendarFold,
} from "lucide-react";
import Footer from "@/components/footer.astro";

// Cloudinary configuration
cloudinary.config({
    cloud_name: import.meta.env.PUBLIC_CLOUDINARY_CLOUD_NAME,
    api_key: import.meta.env.PUBLIC_CLOUDINARY_API_KEY,
    api_secret: import.meta.env.CLOUDINARY_API_SECRET,
});

// Zod schema for Cloudinary metadata
const CloudinaryMetadataSchema = z
    .object({
        make: z.string().optional(),
        model: z.string().optional(),
        focal_length: z.union([z.string(), z.number()]).optional(),
        aperture: z.union([z.string(), z.number()]).optional(),
        exposure_time: z.union([z.string(), z.number()]).optional(),
        iso: z.union([z.string(), z.number()]).optional(),
        CreateDate: z.string().optional(),
    })
    .catchall(z.any());

type CloudinaryMetadata = z.infer<typeof CloudinaryMetadataSchema>;

// Fetch metadata at build time
export async function getStaticPaths() {
    const photos = await getCollection("photos");
    return photos.map((photo) => ({
        params: { public_id: photo.data.public_id },
        props: { photo },
    }));
}

// Props destructure
const { photo } = Astro.props;

// Fetch metadata for this photo
let metadata: CloudinaryMetadata | null = null;
try {
    const result = await cloudinary.api.resource(photo.data.public_id, {
        media_metadata: true,
    });

    metadata = CloudinaryMetadataSchema.parse(result.media_metadata || null);
} catch (err) {
    console.error(`Error fetching metadata for ${photo.data.public_id}`, err);
}

const createDateRaw =
    metadata?.CreateDate !== undefined
        ? metadata?.CreateDate
        : photo.data.created_at; // e.g., '2024:11:03 08:00:40'
let formattedDate = "";

if (createDateRaw) {
    // Replace only the first two colons with dashes
    const isoString = createDateRaw.replace(
        /^(\d{4}):(\d{2}):(\d{2})/,
        "$1-$2-$3",
    );
    const dateObj = new Date(isoString); // JS can parse 'YYYY-MM-DD HH:MM:SS'

    if (!isNaN(dateObj.getTime())) {
        formattedDate = dateObj.toLocaleDateString("en-US", {
            year: "numeric",
            month: "long",
            day: "numeric",
        });
    }
}

const metadataItems = [
    { key: "Make", label: "Camera Make", icon: Camera },
    { key: "Model", label: "Camera Model", icon: Camera },
    { key: "FocalLength", label: "Focal Length", icon: Settings },
    { key: "FNumber", label: "Aperture", icon: Aperture },
    { key: "ExposureTime", label: "Exposure Time", icon: Clock },
    { key: "ISO", label: "ISO", icon: Settings },
    { key: "GPSLatitude", label: "Latitude", icon: Globe },
    { key: "GPSLongitude", label: "Longitude", icon: Globe },
];
---

<html lang="en">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="preconnect" href="https://res.cloudinary.com" crossorigin />
        <title>{`${photo.data.display_name} - Brock Shaffer`}</title>

        <script
            is:inline
            src="https://cdn.jsdelivr.net/npm/gsap@3.13.0/dist/gsap.min.js"
        ></script>
    </head>
    <body>
        <main class="flex flex-col min-h-screen">
            <a
                href="/photos"
                data-astro-prefetch="hover"
                class="z-20 cursor-default ml-2 xl:ml-8 mt-4 mb-4 md:mb-0"
            >
                <Button variant="ghost"> ← Back to Gallery </Button>
            </a>

            <div
                class="grid xl:grid-cols-5 gap-4 md:px-4 md:py-4 xl:px-8 pb-[88px] md:pb-4"
            >
                <div
                    id="photo-card-main"
                    class="xl:col-span-4 aspect-video overflow-hidden opacity-0"
                >
                    <CldImage
                        class="photo-image w-full h-full md:rounded-lg"
                        src={photo.data.public_id}
                        format="auto"
                        dpr="auto"
                        quality="auto:sensitive"
                        loading="eager"
                        fetchpriority="high"
                        decoding="async"
                        width={1920}
                        height={1080}
                        sizes="(max-width: 640px) 100vw, (max-width: 1280px) 80vw, 60vw"
                        alt={photo.data.display_name}
                    />
                </div>

                <div class="flex flex-col p-4">
                    <h1 class="text-3xl font-bold">
                        {photo.data.title ?? "Untitled"}
                    </h1>
                    <h2
                        class="flex items-center text-muted-foreground mt-2 gap-2"
                    >
                        <User className="size-4" />
                        Photo by Brock Shaffer
                    </h2>
                    <h3 class="flex items-center text-muted-foreground gap-2">
                        <CalendarFold className="size-4" />
                        {
                            metadata?.CreateDate !== undefined
                                ? `Created ${formattedDate}`
                                : `Uploaded ${formattedDate}`
                        }
                    </h3>

                    <PhotoActions
                        client:idle
                        publicId={photo.data.public_id}
                        format={photo.data.format}
                    />
                    <Separator className="my-6" />
                    {
                        metadata && (
                            <div class="grid grid-cols-1 gap-4 text-sm text-muted-foreground">
                                {metadataItems.map((item) =>
                                    metadata[item.key] ? (
                                        <p class="flex items-center gap-2">
                                            <item.icon className="size-4" />
                                            <span>
                                                {item.label}:{" "}
                                                {metadata[item.key]}
                                            </span>
                                        </p>
                                    ) : null,
                                )}
                            </div>
                        )
                    }
                </div>
            </div>
        </main>

        <script is:inline>
            (function () {
                const photoCard = document.getElementById("photo-card-main");
                const image = photoCard?.querySelector(".photo-image");

                if (image) {
                    // Set initial state for animation
                    gsap.set("#photo-card-main", {
                        scale: 0.98,
                    });

                    const runAnimation = () => {
                        gsap.to("#photo-card-main", {
                            opacity: 1,
                            scale: 1,
                            duration: 0.6,
                            ease: "power2.out",
                        });
                    };

                    image.onload = runAnimation;

                    if (image.complete && image.naturalHeight !== 0) {
                        runAnimation();
                    }
                }
            })();
        </script>
    </body>
</html>
