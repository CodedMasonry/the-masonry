---
import { ImageFormatConverter } from "@/components/scripts/image-format-converter";
import Main from "@/layouts/main.astro";
---

<Main title="Image Format Converter">
    <main class="min-h-screen bg-background text-foreground">
        <div class="container mx-auto px-4 py-12 max-w-4xl">
            <div class="mb-12 text-center">
                <h1 class="text-4xl md:text-5xl font-bold mb-4 text-balance">
                    Image Format Converter
                </h1>
                <p class="text-lg text-muted-foreground text-balance">
                    Convert your images to PNG, JPEG, or WebP format (including
                    HEIC/HEIF)
                </p>
            </div>
            <ImageFormatConverter client:load />
        </div>
    </main>
</Main>
