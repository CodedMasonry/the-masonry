---
import "@/styles/global.css";
import { getCollection } from "astro:content";
import { CldImage } from "astro-cloudinary";
import PublicNavbar from "@/components/Navbar.astro";
import { ArrowRight } from "lucide-react";
import GridBackground from "@/components/GridBackground.astro";

const photos = await getCollection("photos");
const EAGER_COUNT = 6;
---

<html lang="en">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

        <link rel="preconnect" href="https://res.cloudinary.com" crossorigin />
        <link rel="dns-prefetch" href="https://res.cloudinary.com" />

        <link
            rel="preload"
            href="https://cdn.jsdelivr.net/npm/gsap@3.13.0/dist/gsap.min.js"
            as="script"
        />
        <link
            rel="preload"
            href="https://cdn.jsdelivr.net/npm/gsap@3.13.0/dist/ScrollTrigger.min.js"
            as="script"
        />

        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=Kanit:ital,wght@0,400;0,600&display=swap"
            rel="stylesheet"
            media="print"
            onload="this.media='all'"
        />
        <noscript>
            <link
                href="https://fonts.googleapis.com/css2?family=Kanit:ital,wght@0,400;0,600&display=swap"
                rel="stylesheet"
            />
        </noscript>

        <title>Brock Shaffer - Photo Gallery</title>

        <script
            is:inline
            src="https://cdn.jsdelivr.net/npm/gsap@3.13.0/dist/gsap.min.js"
            defer></script>
        <script
            is:inline
            src="https://cdn.jsdelivr.net/npm/gsap@3.13.0/dist/ScrollTrigger.min.js"
            defer></script>
    </head>
    <body>
        <GridBackground />
        <PublicNavbar />
        <main class="min-h-screen">
            <div class="flex flex-col pb-12 pt-20 mx-4 lg:mx-8">
                <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4">
                    {
                        photos.map((photo, index) => {
                            const isEager = index < EAGER_COUNT;
                            return (
                                <a
                                    id={photo.data.public_id}
                                    href={`/photos/${photo.data.public_id}`}
                                    class="photo-card opacity-0 translate-y-12 scale-95 cursor-default aspect-video relative overflow-hidden group rounded-lg"
                                    data-astro-prefetch="tap"
                                >
                                    <CldImage
                                        class="w-full h-full rounded-lg photo-image object-cover"
                                        src={photo.data.public_id}
                                        format="auto"
                                        quality="auto:eco"
                                        crop="fill"
                                        gravity="auto"
                                        width={800}
                                        height={450}
                                        sizes="(max-width: 768px) 100vw, (max-width: 1024px) 50vw, 33vw"
                                        loading={isEager ? "eager" : "lazy"}
                                        fetchpriority={isEager ? "high" : "low"}
                                        decoding={isEager ? "sync" : "async"}
                                        alt={photo.data.display_name}
                                    />
                                    <div class="arrow-overlay opacity-0 absolute bottom-4 right-4 p-2 bg-white/70 backdrop-blur-sm rounded-full shadow-lg">
                                        <ArrowRight className="h-6 w-6 text-black" />
                                    </div>
                                </a>
                            );
                        })
                    }
                </div>
            </div>
        </main>

        <script is:inline>
            (function () {
                function initGSAP() {
                    if (
                        typeof gsap === "undefined" ||
                        typeof ScrollTrigger === "undefined"
                    )
                        return;

                    gsap.registerPlugin(ScrollTrigger);
                    const cards = gsap.utils.toArray(".photo-card");

                    gsap.set(".arrow-overlay", {
                        xPercent: 15,
                        yPercent: 15,
                    });

                    ScrollTrigger.batch(cards, {
                        interval: 1,
                        onEnter: (batch) =>
                            gsap.to(batch, {
                                opacity: 1,
                                y: 0,
                                scale: 1,
                                duration: 0.6,
                                ease: "power2.out",
                            }),
                    });

                    gsap.matchMedia().add("(min-width: 769px)", () => {
                        cards.forEach((card) => {
                            const image = card.querySelector(".photo-image");
                            const arrow = card.querySelector(".arrow-overlay");

                            const hoverTimeline = gsap.timeline({
                                paused: true,
                                defaults: { duration: 0.3, ease: "power2.out" },
                            });

                            hoverTimeline
                                .to(
                                    image,
                                    { scale: 1.05, z: 0.01, force3D: true },
                                    0,
                                )
                                .to(
                                    arrow,
                                    { opacity: 1, xPercent: 0, yPercent: 0 },
                                    0,
                                );

                            card.addEventListener("mouseenter", () =>
                                hoverTimeline.timeScale(1).play(),
                            );
                            card.addEventListener("mouseleave", () =>
                                hoverTimeline.timeScale(2).reverse(),
                            );
                        });
                    });
                }

                if (document.readyState === "complete") {
                    initGSAP();
                } else {
                    window.addEventListener("load", initGSAP, { once: true });
                }
            })();
        </script>
    </body>
</html>
