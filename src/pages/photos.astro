---
import "@/styles/global.css";
import { getCollection } from "astro:content";
import { CldImage } from "astro-cloudinary";
import Footer from "@/components/footer.astro";
import PublicNavbar from "@/components/public-navbar.astro";
import { ArrowRight } from "lucide-react";
const photos = await getCollection("photos");

// Define how many photos are "above the fold" for the initial stagger animation
const ABOVE_THE_FOLD_COUNT = 6;
const staggeredPhotos = photos.slice(0, ABOVE_THE_FOLD_COUNT);
const OtherPhotos = photos.slice(ABOVE_THE_FOLD_COUNT);
---

<html lang="en">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="preconnect" href="https://res.cloudinary.com" crossorigin />
        <title>Brock Shaffer - Photo Gallery</title>
        <script
            is:inline
            src="https://cdn.jsdelivr.net/npm/gsap@3.13.0/dist/gsap.min.js"
        ></script>
        <script
            is:inline
            src="https://cdn.jsdelivr.net/npm/gsap@3.13.0/dist/ScrollTrigger.min.js"
        ></script>
    </head>
    <body>
        <PublicNavbar />
        <main class="min-h-screen">
            <div class="flex flex-col mb-16 mx-4 lg:mx-8">
                <div class="flex flex-col mt-24 mb-16">
                    <h1 class="text-4xl font-extrabold underline">
                        The Gallery
                    </h1>
                    <p class="mt-2 text-muted-foreground">
                        It's the small details that matter most.
                    </p>
                </div>
                <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4">
                    {
                        staggeredPhotos.map((photo, index) => (
                            <a
                                href={`/photos/${photo.data.public_id}`}
                                class="aspect-video cursor-default photo-stagger photo-card opacity-0 relative overflow-hidden group rounded-lg"
                                data-astro-prefetch="tap"
                            >
                                <CldImage
                                    class="w-full h-full rounded-lg photo-image"
                                    src={photo.data.public_id}
                                    format="auto"
                                    dpr="auto"
                                    width="600"
                                    quality="auto:low"
                                    loading={index < 4 ? "eager" : "lazy"}
                                    fetchpriority={index === 0 ? "high" : "low"}
                                    decoding="async"
                                    sizes="(max-width: 640px) 100vw, (max-width: 1024px) 50vw, (max-width: 1536px) 33vw, 25vw"
                                    alt={photo.data.display_name}
                                />
                                <div class="arrow-overlay absolute bottom-4 right-4 p-2 bg-white/70 backdrop-blur-sm rounded-full shadow-lg">
                                    <ArrowRight className="h-6 w-6 text-black" />
                                </div>
                            </a>
                        ))
                    }
                </div>
                <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4 mt-16">
                    {
                        OtherPhotos.map((photo, index) => (
                            <a
                                href={`/photos/${photo.data.public_id}`}
                                class="aspect-video cursor-default photo-scroll photo-card relative overflow-hidden group rounded-lg"
                                data-astro-prefetch="tap"
                            >
                                <CldImage
                                    class="w-full h-full rounded-lg photo-image"
                                    src={photo.data.public_id}
                                    format="auto"
                                    dpr="auto"
                                    quality="auto"
                                    loading="lazy"
                                    fetchpriority="low"
                                    decoding="async"
                                    sizes="(max-width: 640px) 100vw, (max-width: 1024px) 50vw, (max-width: 1536px) 33vw, 25vw"
                                    alt={photo.data.display_name}
                                />
                                <div class="arrow-overlay absolute bottom-4 right-4 p-2 bg-white/70 backdrop-blur-sm rounded-full shadow-lg">
                                    <ArrowRight className="h-6 w-6 text-black" />
                                </div>
                            </a>
                        ))
                    }
                </div>
            </div>
            <Footer />
        </main>

        <script is:inline>
            (function () {
                gsap.registerPlugin(ScrollTrigger);

                // Initial state
                gsap.set(".photo-stagger", {
                    y: 50,
                    scale: 0.95,
                });
                gsap.set(".arrow-overlay", {
                    opacity: 0,
                    xPercent: 10,
                    yPercent: 10,
                });

                // Initial Stagger on load
                window.addEventListener("load", () => {
                    gsap.to(".photo-stagger", {
                        opacity: 1,
                        yPercent: 0,
                        scale: 1,
                        duration: 0.6,
                        stagger: 0.1,
                        ease: "power2.out",
                    });
                    ScrollTrigger.refresh();
                });

                // Hover Animation Logic
                const photoCards = gsap.utils.toArray(".photo-card");
                photoCards.forEach((card) => {
                    const image = card.querySelector(".photo-image");
                    const arrow = card.querySelector(".arrow-overlay");

                    const hoverTimeline = gsap.timeline({
                        paused: true,
                        defaults: { duration: 0.3, ease: "power2.out" },
                    });

                    hoverTimeline
                        .to(
                            image,
                            {
                                scale: 1.05,
                                z: 0.01,
                                force3D: true,
                            },
                            0,
                        )
                        .to(arrow, { opacity: 1, xPercent: 0, yPercent: 0 }, 0);

                    card.addEventListener("mouseenter", () =>
                        hoverTimeline.timeScale(1).play(),
                    );
                    card.addEventListener("mouseleave", () =>
                        hoverTimeline.timeScale(2).reverse(),
                    );
                });
            })();
        </script>
    </body>
</html>
