---
import Animated from "@/layouts/animated.astro";
import { CldImage } from "astro-cloudinary";

// We only need one image, as we'll reveal it
const heroImage = "DJI_20251108110602_0075_D_j0ie3e";
---

<Animated title="Brock Shaffer">
    <section class="relative h-[90vh] w-full overflow-hidden">
        <div class="absolute inset-0 z-0 h-full w-full">
            <CldImage
                src={heroImage}
                alt="Hero background"
                format="auto"
                quality="auto"
                width={8064}
                height={4536}
                sizes="100vw"
                loading="eager"
                fetchpriority="high"
                decoding="async"
                class="h-full w-full object-cover brightness-90"
            />
        </div>

        <div class="absolute inset-0 z-10 flex">
            <div class="reveal-block h-full w-[20%] bg-background"></div>
            <div class="reveal-block h-full w-[20%] bg-background"></div>
            <div class="reveal-block h-full w-[20%] bg-background"></div>
            <div class="reveal-block h-full w-[20%] bg-background"></div>
            <div class="reveal-block h-full w-[20%] bg-background"></div>
        </div>

        <div class="absolute bottom-16 left-4 md:left-8 z-20 flex">
            <h1
                class="hero-title opacity-0 -translate-y-32 text-6xl lg:text-9xl text-foreground drop-shadow-[0_2px_2px_rgba(0,0,0,0.8)] md:text-7xl text-center"
            >
                BROCK SHAFFER
            </h1>
        </div>
    </section>
</Animated>

<style>
    .hero-image-mask {
        mask-image: linear-gradient(to bottom, black 70%, transparent 100%);
        -webkit-mask-image: linear-gradient(
            to bottom,
            black 70%,
            transparent 100%
        );
    }

    .hero-title {
        font-family: "Antonio", sans-serif;
        font-optical-sizing: auto;
        font-weight: 700;
        font-style: normal;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
    }
</style>

<script is:inline>
    (function () {
        document.addEventListener("DOMContentLoaded", () => {
            // 1. Animate the 5 "falling blocks"
            gsap.to(".reveal-block", {
                yPercent: 100,
                duration: 1.2,
                stagger: 0.1,
                ease: "power3.out",
                delay: 0.5,
            });

            // 2. Animate the title in *after* the blocks start moving
            gsap.to(".hero-title", {
                opacity: 1,
                y: 0,
                duration: 1,
                ease: "power3.out",
                delay: 1,
            });
        });
    })();
</script>
