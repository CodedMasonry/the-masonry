---
// Components
import { CycleText } from "@/components/home/cycle-text";
import { Button } from "@/components/ui/button";
import HighSchoolGridItem from "@/components/home/HighSchoolGridItem.astro";

// Icons
import PaperIcon from "@/assets/icons/paper.svg";
import PhotoIcon from "@/assets/icons/photo.svg";
import LinkedInIcon from "@/assets/icons/linkedin.svg";
import GithubIcon from "@/assets/icons/github.svg";
import YPAImage from "@/assets/icons/ypa.png";
import OutcomesImage from "@/assets/icons/outcomes.png";
import RoboticsTeamImage from "@/assets/icons/team1014.jpeg";
import FSTImage from "@/assets/icons/fst.jpeg";

// Other imports
import Main from "@/layouts/main.astro";
import { CldImage } from "astro-cloudinary";
---

<Main title="Brock Shaffer">
    <section class="relative h-[90vh] w-full">
        <div
            class="absolute inset-0 h-full w-full"
            style="mask-image: linear-gradient(to bottom, black 70%, transparent 100%); -webkit-mask-image: linear-gradient(to bottom, black 70%, transparent 100%);"
        >
            <CldImage
                src="damA2_09_20_25_rkfd0k"
                alt="Hero background"
                format="auto"
                quality="auto"
                width={8064}
                height={4536}
                sizes="100vw"
                loading="eager"
                fetchpriority="high"
                decoding="async"
                class="h-full w-full z-0 object-cover"
            />
        </div>
    </section>
    <div
        class="absolute inset-0 w-full h-[90vh] flex flex-col items-center justify-center space-y-4"
    >
        <h1
            class="font-extrabold text-6xl text-primary drop-shadow-[0_2px_2px_rgba(0,0,0,0.8)] md:text-7xl text-center"
        >
            Hello, I&apos;m Brock.
        </h1>
        <div class="grid grid-cols-1 md:grid-cols-4 gap-4 w-fit mt-4"></div>
    </div>
</Main>
