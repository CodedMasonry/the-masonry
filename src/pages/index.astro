---
import "@/styles/global.css";
import { DownloadCloud, LoaderCircle } from "lucide-react";

// We only need one image, as we'll reveal it
const heroImage = "DJI_20251108110602_0075_D_j0ie3e";
---

<html lang="en">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="preconnect" href="https://res.cloudinary.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=Antonio:wght@100..700&family=Kanit:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,100;1,200;1,300;1,400;1,500;1,600;1,700;1,800;1,900&display=swap"
            rel="stylesheet"
        />

        <title>Brock Shaffer</title>

        <script
            is:inline
            src="https://cdn.jsdelivr.net/npm/gsap@3.13.0/dist/gsap.min.js"
        ></script>
        <script
            is:inline
            src="https://cdn.jsdelivr.net/npm/gsap@3.13.0/dist/TextPlugin.min.js"
        ></script>
    </head>

    <body>
        <main class="min-h-screen relative">
            <div
                class="loading-screen fixed inset-0 z-40 flex flex-col w-full h-full text-center"
            >
                <div class="flex flex-col mx-auto my-auto items-center">
                    <DownloadCloud className="loading-icon" size={32} />
                    <div class="loading-bar h-1 bg-muted w-12 rounded mt-2">
                    </div>
                </div>
            </div>
        </main>
    </body>
</html>

<style>
    .loading-title {
        font-family: "Kanit";
    }
</style>

<script is:inline>
    document.addEventListener("DOMContentLoaded", () => {
        gsap.to(".loading-bar", {
            duration: 1,
            backgroundColor: "var(--foreground)",
            ease: "power3.out",
            repeat: -1,
            yoyo: true,
        });
    });
</script>
