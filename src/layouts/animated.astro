---
import PublicNavbar from "@/components/public-navbar.astro";
import "@/styles/global.css";

interface Props {
    title: string;
}
const props = Astro.props;
---

<html lang="en">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="preconnect" href="https://res.cloudinary.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=Anton&family=Antonio:wght@100..700&family=Kanit:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,100;1,200;1,300;1,400;1,500;1,600;1,700;1,800;1,900&display=swap"
            rel="stylesheet"
        />

        <title>{props.title}</title>

        <script
            is:inline
            src="https://cdn.jsdelivr.net/npm/gsap@3.13.0/dist/gsap.min.js"
        ></script>
        <script
            is:inline
            src="https://cdn.jsdelivr.net/npm/gsap@3.13.0/dist/ScrollTrigger.min.js"
        ></script>
    </head>
    <body>
        <header class="fixed top-0 left-0 w-full z-50">
            <PublicNavbar />
        </header>
        <main class="min-h-screen relative">
            <slot />
        </main>
    </body>
</html>
